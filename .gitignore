# Python virtual environment
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# Environment / secrets
.env.local
.env.*.local

# Frontend build output
frontend/dist/

# Node modules
node_modules/
frontend/node_modules/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
*.swp
*.swo

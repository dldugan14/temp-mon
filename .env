# ──────────────────────────────────────────────
# Temp-Mon Configuration
# ──────────────────────────────────────────────

# Fan relay – turns ON when any sensor >= FAN_ON_TEMP
#             turns OFF when all sensors <= FAN_OFF_TEMP
FAN_ON_TEMP=30.0
FAN_OFF_TEMP=25.0

# Battery relay – turns ON when any sensor >= BAT_ON_TEMP
#                 turns OFF when all sensors <= BAT_OFF_TEMP
BAT_ON_TEMP=40.0
BAT_OFF_TEMP=35.0

# GPIO BCM pin numbers (Raspberry Pi)
FAN_RELAY_PIN=17
BAT_RELAY_PIN=27

# How often (seconds) the controller reads sensors
POLL_INTERVAL=5

# FastAPI server port
PORT=8000

# Set to "true" on non-Pi hardware to use simulated sensor data
SIMULATE=false

# ──────────────────────────────────────────────
# RS485 / Modbus RTU temperature sensors
# ──────────────────────────────────────────────
# Set to "false" to disable
MODBUS_ENABLED=false

# Serial port the RS485 adapter is on
MODBUS_PORT=/dev/serial0
MODBUS_BAUD=9600

# Comma-separated list of Modbus unit IDs to poll
# e.g. 3 sensors with IDs 1,2,3
MODBUS_UNIT_IDS=1,2,3

# Holding register address that holds temperature (16-bit signed)
MODBUS_TEMP_REGISTER=0

# Multiply raw register value by this to get °C  (0.1 = value/10)
MODBUS_TEMP_SCALE=0.1

# Per-sensor read timeout in seconds
MODBUS_TIMEOUT=1.0

# ──────────────────────────────────────────────
# JK BMS (Battery Management System)
# ──────────────────────────────────────────────
# Source: rs485 | can
JK_BMS_SOURCE=can

# Set to "true" to enable JK BMS monitoring
JK_BMS_ENABLED=false

# Serial port (same as RS485, shared with Modbus)
JK_BMS_PORT=/dev/serial0

# Baud rate (JK BMS typically uses 115200)
JK_BMS_BAUD=115200

# Modbus unit ID of the BMS (typically 1)
JK_BMS_UNIT_ID=1

# Number of cells in the battery pack (8-24 typical)
JK_BMS_NUM_CELLS=16

# Read timeout in seconds
JK_BMS_TIMEOUT=1.0

# CAN telemetry decoder (used when JK_BMS_SOURCE=can)
JK_BMS_CAN_ENABLED=true
JK_BMS_CAN_PACK_ID=0x351
JK_BMS_CAN_TEMP_ID=0x355
JK_BMS_CAN_CELL_BASE_ID=0x360
JK_BMS_CAN_CELL_FRAME_COUNT=4
JK_BMS_CAN_VOLTAGE_SCALE=0.1
JK_BMS_CAN_CURRENT_SCALE=0.1
JK_BMS_CAN_SOC_SCALE=1.0
JK_BMS_CAN_CELL_SCALE=0.001
JK_BMS_CAN_CURRENT_SIGNED=true
JK_BMS_CAN_CURRENT_OFFSET=0
JK_BMS_CAN_TEMP_OFFSET=-40
JK_BMS_CAN_NO_FRAME_TIMEOUT=10

# ──────────────────────────────────────────────
# CAN bus relay commander
# ──────────────────────────────────────────────
# Set to "false" to disable
CAN_ENABLED=true

# SocketCAN interface name (MCP2515 SPI module registers as can0)
CAN_INTERFACE=can0

# Bitrate in bps for the CAN bus
CAN_BITRATE=500000

# Arbitration ID this controller listens on for relay commands (hex ok)
# Frame format: byte[0]=relay (0=fan,1=battery)  byte[1]=cmd (0=off,1=on,2=auto)
CAN_RELAY_CMD_ID=0x100
